container_commands:
  01_npm_build:
    command: "npm ci && npm run build"
    leader_only: true

  02_storage_link:
    command: "php artisan storage:link --force"
    leader_only: true

  03_migrate:
    command: "php artisan migrate --force"
    leader_only: true

  04_db_seed:
    command: "php artisan db:seed --force"
    leader_only: true

  05_cache:
    command: "php artisan config:cache && php artisan route:cache && php artisan view:cache"
    leader_only: true

  06_permissions:
    command: "chmod -R 775 storage bootstrap/cache && chown -R webapp:webapp storage bootstrap/cache"
